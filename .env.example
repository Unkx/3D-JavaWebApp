# Copy to .env and fill in real values before running docker compose.
# Spring Boot reads these as environment variables (see application.properties).

# --- Database ---
DB_URL=jdbc:postgresql://localhost:5432/3D-JavaApp
DB_USERNAME=postgres
DB_PASSWORD=

# --- JWT ---
# REQUIRED for Docker. Generate with: openssl rand -base64 48
JWT_SECRET=
# Token lifetime in milliseconds (default 7 days)
JWT_EXPIRATION=604800000

# --- CORS ---
# Comma-separated list of allowed origins.
# Dev: http://localhost:4200
# Prod: https://druk3d.pl,https://www.druk3d.pl
ALLOWED_ORIGINS=http://localhost:4200

# --- Upload size ---
# Max STL upload size (default 25MB if unset)
UPLOAD_MAX_SIZE=25MB

# --- Default admin account (seeded on first startup) ---
ADMIN_EMAIL=admin@druk3d.pl
ADMIN_PASSWORD=admin123
